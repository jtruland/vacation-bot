# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_token_here
BOT_OWNER_ID=your_telegram_user_id  # required — receive new-group approval requests and use admin commands

# SerpApi — sign up free at https://serpapi.com (250 searches/month free)
# Provides live flight and hotel search via Google Flights / Google Hotels
SERPAPI_KEY=your_serpapi_key_here

# Gmail — required for !claude scan email and daily booking scan
# Use a 16-char app password from myaccount.google.com/apppasswords (not your login password)
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_SCAN_DAYS=90  # how far back to search (default: 90)

# MCP gateway (mcp.bitz.dev) — required for gas price tools (search_gas_nearby, search_gas_along_route)
# Add an API key auth path to the gateway, then set this value.
MCP_API_KEY=your_mcp_api_key_here

# Bot behavior
TRIGGER_WORD=!claude

# Bootstrap only — comma-separated list of chat IDs to pre-allow on first run.
# Ignored after data/admin_config.json is created. Use !claude admin commands instead.
ALLOWED_CHAT_IDS=
